#!/bin/bash
#SBATCH --job-name=blis_perf
#SBATCH --output=blis_perf.log
#SBATCH --array=1-@NUM_THREAD_BLOCKS@
@SBATCH_ARGS@

# ====================================================================
# BLIS Performance Data Collection Batch Script
# Generated by collect_perfdata.py
# ====================================================================
# Edit SLURM options above as needed for your system.
# This script is intended to be run manually or via SLURM, not by
# collect_perfdata.py itself.
# ====================================================================

# Configuration
COMMIT_DIR="@COMMIT_DIR@"
BLIS_DIR="@BLIS_DIR@"
THREADS_ARRAY=(@THREADS_ARRAY@)
LO_ARRAY=(@LO_ARRAY@)
HI_ARRAY=(@HI_ARRAY@)
STEP_ARRAY=(@STEP_ARRAY@)
MACHINE="@MACHINE@"
CONFIG="@CONFIG@"
GIT_COMMIT="@GIT_COMMIT@"
SCRIPTS_DIR="@SCRIPTS_DIR@"

# Check if running as a SLURM array job
if [ ! -z "$SLURM_ARRAY_TASK_ID" ]; then
    THREADS_ARRAY=(${THREADS_ARRAY[$SLURM_ARRAY_TASK_ID-1]})
    LO_ARRAY=(${LO_ARRAY[$SLURM_ARRAY_TASK_ID-1]})
    HI_ARRAY=(${HI_ARRAY[$SLURM_ARRAY_TASK_ID-1]})
    STEP_ARRAY=(${STEP_ARRAY[$SLURM_ARRAY_TASK_ID-1]})
fi

# Substitution variables for input file generation
DT="@DT@"
MSTORAGE="@MSTORAGE@"
VSTORAGE="@VSTORAGE@"
REPEAT="@REPEAT@"
M1="@1M@"
NATIVE="@NATIVE@"
LEVEL2="@LEVEL2@"
LEVEL3="@LEVEL3@"

# Verify BLIS directory and test executable
if [ ! -d "$BLIS_DIR" ]; then
    echo "Error: BLIS directory not found: $BLIS_DIR"
    exit 1
fi

TEST_EXEC="$BLIS_DIR/test_libblis.x"
if [ ! -x "$TEST_EXEC" ]; then
    echo "Error: Test executable not found or not executable: $TEST_EXEC"
    exit 1
fi

echo "=========================================="
echo "BLIS Performance Data Collection"
echo "=========================================="
echo "Output directory: $COMMIT_DIR"
echo "BLIS directory: $BLIS_DIR"
echo "Test executable: $TEST_EXEC"
echo "Machine: $MACHINE"
echo "Config: $CONFIG"
echo "Git commit: $GIT_COMMIT"
echo ""

# Loop over thread configurations
for i in "${!THREADS_ARRAY[@]}"; do
    THREADS=${THREADS_ARRAY[$i]}
    LO=${LO_ARRAY[$i]}
    HI=${HI_ARRAY[$i]}
    STEP=${STEP_ARRAY[$i]}

    echo "=========================================="
    echo "Iteration $((i+1)): threads=$THREADS lo=$LO hi=$HI step=$STEP"
    echo "=========================================="

    # Set thread count
    export BLIS_NUM_THREADS=$THREADS

    # Process input.general.in
    echo "Generating input.general..."
    sed -e "s/@lo@/$LO/g" \
        -e "s/@hi@/$HI/g" \
        -e "s/@step@/$STEP/g" \
        -e "s/@dt@/$DT/g" \
        -e "s/@mstorage@/$MSTORAGE/g" \
        -e "s/@vstorage@/$VSTORAGE/g" \
        -e "s/@repeat@/$REPEAT/g" \
        -e "s/@1m@/$M1/g" \
        -e "s/@native@/$NATIVE/g" \
        "$SCRIPTS_DIR/input.general.in" > input.general

    # Process input.operations.in
    echo "Generating input.operations..."
    sed -e "s/[01]        # Utility/0        # Utility/g" \
        -e "s/[01]        # Level-1v kernels/0        # Level-1v kernels/g" \
        -e "s/[01]        # Level-1m/0        # Level-1m/g" \
        -e "s/[01]        # Level-1f kernels/0        # Level-1f kernels/g" \
        -e "s/[01]        # Level-2/$LEVEL2        # Level-2/g" \
        -e "s/[01]        # Level-3 micro-kernels/0        # Level-3 micro-kernels/g" \
        -e "s/[01]        # Level-3$/$LEVEL3        # Level-3$/g" \
        -e "s/[01]        # Level-4/0        # Level-4/g" \
        -e "s/[01]        # gemm$/1        # gemm/g" \
        -e "s/[01]        # gemmt/1        # gemmt/g" \
        -e "s/[01]        # hemm/1        # hemm/g" \
        -e "s/[01]        # herk/1        # herk/g" \
        -e "s/[01]        # her2k/1        # her2k/g" \
        -e "s/[01]        # symm/0        # symm/g" \
        -e "s/[01]        # syrk/0        # syrk/g" \
        -e "s/[01]        # syr2k/0        # syr2k/g" \
        -e "s/[01]        # trmm$/0        # trmm/g" \
        -e "s/[01]        # trmm3/1        # trmm3/g" \
        -e "s/[01]        # trsm/1        # trsm/g" \
        "$BLIS_DIR/testsuite/input.operations" > input.operations

    # Run the test suite
    echo "Running test suite..."
    if [ "x$VERBOSE" = "x1" ]; then
        "$TEST_EXEC" | tee $COMMIT_DIR/output.testsuite.$THREADS
    else
        "$TEST_EXEC" > $COMMIT_DIR/output.testsuite.$THREADS
    fi

    if grep -q "Exiting normally." $COMMIT_DIR/output.testsuite.$THREADS; then
        echo "Test suite completed successfully"
    else
        echo "Warning: Test suite exited abnormally"
    fi

    #rm -f input.general input.operations

    echo ""
done

echo "=========================================="
echo "All iterations completed"
echo "=========================================="
