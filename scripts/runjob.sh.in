#!/bin/bash
#SBATCH --job-name=blis_perf
#SBATCH --output=blis_perf.log
#SBATCH --time=12:00:00

# ====================================================================
# BLIS Performance Data Collection Batch Script
# Generated by collect_perfdata.py
# ====================================================================
# Edit SLURM options above as needed for your system.
# This script is intended to be run manually or via SLURM, not by
# collect_perfdata.py itself.
# ====================================================================

set -e

# Configuration
BLIS_DIR="@BLIS_DIR@"
THREADS_ARRAY=(@THREADS_ARRAY@)
LO_ARRAY=(@LO_ARRAY@)
HI_ARRAY=(@HI_ARRAY@)
STEP_ARRAY=(@STEP_ARRAY@)
MACHINE="@MACHINE@"
CONFIG="@CONFIG@"
DB_FILE="@DB_FILE@"
GIT_COMMIT="@GIT_COMMIT@"
SCRIPTS_DIR="@SCRIPTS_DIR@"

# Substitution variables for input file generation
DT="@DT@"
MSTORAGE="@MSTORAGE@"
VSTORAGE="@VSTORAGE@"
REPEAT="@REPEAT@"
M1="@1M@"
NATIVE="@NATIVE@"
LEVEL2="@LEVEL2@"
LEVEL3="@LEVEL3@"

# Verify BLIS directory and test executable
if [ ! -d "$BLIS_DIR" ]; then
    echo "Error: BLIS directory not found: $BLIS_DIR"
    exit 1
fi

TEST_EXEC="$BLIS_DIR/test_libblis.x"
if [ ! -x "$TEST_EXEC" ]; then
    echo "Error: Test executable not found or not executable: $TEST_EXEC"
    exit 1
fi

echo "=========================================="
echo "BLIS Performance Data Collection"
echo "=========================================="
echo "BLIS directory: $BLIS_DIR"
echo "Test executable: $TEST_EXEC"
echo "Machine: $MACHINE"
echo "Config: $CONFIG"
echo "Git commit: $GIT_COMMIT"
echo "Database: $DB_FILE"
echo ""

# Loop over thread configurations
for i in "${!THREADS_ARRAY[@]}"; do
    THREADS=${THREADS_ARRAY[$i]}
    LO=${LO_ARRAY[$i]}
    HI=${HI_ARRAY[$i]}
    STEP=${STEP_ARRAY[$i]}

    echo "=========================================="
    echo "Iteration $((i+1)): threads=$THREADS lo=$LO hi=$HI step=$STEP"
    echo "=========================================="

    # Set thread count
    export BLIS_NUM_THREADS=$THREADS

    # Process input.general.in
    echo "Generating input.general..."
    sed -e "s/@lo@/$LO/g" \
        -e "s/@hi@/$HI/g" \
        -e "s/@step@/$STEP/g" \
        -e "s/@dt@/$DT/g" \
        -e "s/@mstorage@/$MSTORAGE/g" \
        -e "s/@vstorage@/$VSTORAGE/g" \
        -e "s/@repeat@/$REPEAT/g" \
        -e "s/@1m@/$M1/g" \
        -e "s/@native@/$NATIVE/g" \
        "$SCRIPTS_DIR/input.general.in" > input.general

    # Process input.operations.in
    echo "Generating input.operations..."
    sed -e "s/@level2@/$LEVEL2/g" \
        -e "s/@level3@/$LEVEL3/g" \
        "$SCRIPTS_DIR/input.operations.in" > input.operations

    # Run the test suite
    echo "Running test suite..."
    if "$TEST_EXEC" | tee output.testsuite; then
        echo "Test suite completed successfully"
    else
        echo "Warning: Test suite exited with non-zero status"
    fi

    # Import results into database
    echo "Importing results into database..."
    python3 "$SCRIPTS_DIR/import_testsuite.py" output.testsuite "$DB_FILE" "$MACHINE"

    echo ""
done

echo "=========================================="
echo "All iterations completed"
echo "=========================================="
